{
  "globalHeaders": {
    "Content-Security-Policy": "frame-ancestors 'none'",
    "X-Frame-Options": "DENY"
  },
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
